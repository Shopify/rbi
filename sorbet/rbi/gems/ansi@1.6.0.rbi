  def bar_mark=(mark); end

  # pkg:gem/ansi#lib/ansi/progressbar.rb:57
  def barmark=(mark); end

  # pkg:gem/ansi#lib/ansi/progressbar.rb:138
  def clear; end

  # For backward compatability
  #
  # pkg:gem/ansi#lib/ansi/progressbar.rb:91
  def file_transfer_mode; end

  # pkg:gem/ansi#lib/ansi/progressbar.rb:93
