  # pkg:gem/ansi#lib/ansi/progressbar.rb:99
  def flush; end

  # Set format and format arguments.
  #
  # pkg:gem/ansi#lib/ansi/progressbar.rb:45
  def format(format, *arguments); end

  # Set format and format arguments.
  #
  # pkg:gem/ansi#lib/ansi/progressbar.rb:45
  def format=(_arg0); end

  # pkg:gem/ansi#lib/ansi/progressbar.rb:46
  def format_arguments; end

  # pkg:gem/ansi#lib/ansi/progressbar.rb:46
  def format_arguments=(_arg0); end

  # pkg:gem/ansi#lib/ansi/progressbar.rb:103
  def halt; end

  # pkg:gem/ansi#lib/ansi/progressbar.rb:130
  def inc(step = T.unsafe(nil)); end

  # pkg:gem/ansi#lib/ansi/progressbar.rb:142
  def inspect; end

  # pkg:gem/ansi#lib/ansi/progressbar.rb:58
  def mark=(mark); end

  # pkg:gem/ansi#lib/ansi/progressbar.rb:124
  def reset; end

  # pkg:gem/ansi#lib/ansi/progressbar.rb:108
  def set(count); end

  # pkg:gem/ansi#lib/ansi/progressbar.rb:79
  def standard_mode; end

  # Set ANSI styling options.
  #
  # pkg:gem/ansi#lib/ansi/progressbar.rb:74
  def style(options); end

  # pkg:gem/ansi#lib/ansi/progressbar.rb:47
