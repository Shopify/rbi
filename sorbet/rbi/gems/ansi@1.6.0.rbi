# pkg:gem/ansi#lib/ansi/chart.rb:86
ANSI::SPECIAL_CHART = T.let(T.unsafe(nil), Hash)

# IMPORTANT! ANSI::String is experimental!!!
#
# ANSI::String stores a regular string (`@text`) and an associative
# array that ties a character index to an ANSI code (`marks`).
# For example is we have the string:
#
#   "Big Apple"
#
# And applied the color red to it, the marks list would be:
#
#   [[0, :red], [9, :clear]]
#
# TODO: In the future we may be able to subclass String,
# instead of delegating via @text, but not until it is more
# compatible.
#
# pkg:gem/ansi#lib/ansi/string.rb:25
class ANSI::String
  # New Ansi::String
  #
  # pkg:gem/ansi#lib/ansi/string.rb:33
  def initialize(text = T.unsafe(nil), marks = T.unsafe(nil)); end

  # Add one String to another, or to a regular String.
  #
  # pkg:gem/ansi#lib/ansi/string.rb:73
  def +(other); end

  # pkg:gem/ansi#lib/ansi/string.rb:132
  def [](*args); end

  # pkg:gem/ansi#lib/ansi/string.rb:194
  def ansi(code); end

  # pkg:gem/ansi#lib/ansi/string.rb:204
  def ansi!(code); end

  # pkg:gem/ansi#lib/ansi/string.rb:214
  def black; end

  # pkg:gem/ansi#lib/ansi/string.rb:225
  def black!; end

  # pkg:gem/ansi#lib/ansi/string.rb:213
  def blue; end

  # pkg:gem/ansi#lib/ansi/string.rb:224
  def blue!; end

  # pkg:gem/ansi#lib/ansi/string.rb:219
  def bold; end

  # pkg:gem/ansi#lib/ansi/string.rb:230
  def bold!; end

  # pkg:gem/ansi#lib/ansi/string.rb:201
  def color(code); end

  # pkg:gem/ansi#lib/ansi/string.rb:209
  def color!(code); end

  # pkg:gem/ansi#lib/ansi/string.rb:217
  def cyan; end

  # pkg:gem/ansi#lib/ansi/string.rb:228
  def cyan!; end

  # Downcase the string.
  #
  # pkg:gem/ansi#lib/ansi/string.rb:69
  def downcase; end

  # pkg:gem/ansi#lib/ansi/string.rb:70
  def downcase!; end

  # pkg:gem/ansi#lib/ansi/string.rb:212
  def green; end

  # pkg:gem/ansi#lib/ansi/string.rb:223
  def green!; end

  # See #gsub!.
  #
  # pkg:gem/ansi#lib/ansi/string.rb:189
  def gsub(pattern, replacement = T.unsafe(nil), &block); end

  # pkg:gem/ansi#lib/ansi/string.rb:163
  def gsub!(pattern, replacement = T.unsafe(nil), &block); end

  # pkg:gem/ansi#lib/ansi/string.rb:215
  def magenta; end

  # pkg:gem/ansi#lib/ansi/string.rb:226
  def magenta!; end

  # pkg:gem/ansi#lib/ansi/string.rb:30
  def marks; end

  # pkg:gem/ansi#lib/ansi/string.rb:211
  def red; end

  # pkg:gem/ansi#lib/ansi/string.rb:222
  def red!; end

  # The size of the base text.
  #
  # pkg:gem/ansi#lib/ansi/string.rb:62
  def size; end

  # slice
  #
  # pkg:gem/ansi#lib/ansi/string.rb:98
  def slice(*args); end

  # See #sub!.
  #
  # pkg:gem/ansi#lib/ansi/string.rb:158
  def sub(pattern, replacement = T.unsafe(nil), &block); end

  # This is more limited than the normal String method.
  # It does not yet support a block, and +replacement+
  # won't substitue for \1, \2, etc.
  #
  # TODO: block support.
  #
  # pkg:gem/ansi#lib/ansi/string.rb:139
  def sub!(pattern, replacement = T.unsafe(nil), &block); end

  # pkg:gem/ansi#lib/ansi/string.rb:29
  def text; end

  # Convert Ansi::String object to normal String.
  # This converts the intental markup codes to ANSI codes.
  #
  # pkg:gem/ansi#lib/ansi/string.rb:41
  def to_s; end

  # ANSI::String is a type of String.
  #
  # pkg:gem/ansi#lib/ansi/string.rb:59
  def to_str; end

  # pkg:gem/ansi#lib/ansi/string.rb:220
  def underline; end

  # pkg:gem/ansi#lib/ansi/string.rb:231
  def underline!; end

  # Upcase the string.
  #
  # pkg:gem/ansi#lib/ansi/string.rb:65
  def upcase; end

  # pkg:gem/ansi#lib/ansi/string.rb:66
  def upcase!; end

  # pkg:gem/ansi#lib/ansi/string.rb:216
  def yellow; end

  # pkg:gem/ansi#lib/ansi/string.rb:227
  def yellow!; end

  private

  # pkg:gem/ansi#lib/ansi/string.rb:236
  def shift_marks(index, delta, marks = T.unsafe(nil)); end

  # pkg:gem/ansi#lib/ansi/string.rb:250
  def shift_marks!(index, delta); end
end

# pkg:gem/ansi#lib/ansi/string.rb:27
ANSI::String::CLR = T.let(T.unsafe(nil), String)

# pkg:gem/ansi#lib/ansi/table.rb:6
class ANSI::Table
  # The Table class can be used to output nicely formatted
  # tables with division lines and alignment.
  #
  # table - array of array
  #
  # options[:align]   - align :left or :right
  # options[:padding] - space to add to each cell
  # options[:fit]     - fit to screen width
  # options[:border]  -
  #
  # The +format+ block must return ANSI codes to apply
  # to each cell.
  #
  # Other Implementations:
  #
  # * http://github.com/visionmedia/terminal-table
  # * http://github.com/aptinio/text-table
  #
  # TODO: Support for table headers and footers.
  #
  # pkg:gem/ansi#lib/ansi/table.rb:27
  def initialize(table, options = T.unsafe(nil), &format); end

  # pkg:gem/ansi#lib/ansi/table.rb:49
  def align; end

  # pkg:gem/ansi#lib/ansi/table.rb:49
  def align=(_arg0); end

  # pkg:gem/ansi#lib/ansi/table.rb:55
  def border; end

  # pkg:gem/ansi#lib/ansi/table.rb:55
  def border=(_arg0); end

  # Fit to scree width.
  #
  # pkg:gem/ansi#lib/ansi/table.rb:43
  def fit; end

  # Fit to scree width.
  #
  # pkg:gem/ansi#lib/ansi/table.rb:43
  def fit=(_arg0); end

  # pkg:gem/ansi#lib/ansi/table.rb:52
  def format; end

  # pkg:gem/ansi#lib/ansi/table.rb:52
  def format=(_arg0); end

  # pkg:gem/ansi#lib/ansi/table.rb:46
  def padding; end

  # pkg:gem/ansi#lib/ansi/table.rb:46
  def padding=(_arg0); end

  # pkg:gem/ansi#lib/ansi/table.rb:40
  def table; end

  # pkg:gem/ansi#lib/ansi/table.rb:40
  def table=(_arg0); end

  # pkg:gem/ansi#lib/ansi/table.rb:58
  def to_s; end

  private

  # pkg:gem/ansi#lib/ansi/table.rb:158
  def ansi_formating(cell, col, row); end

  # pkg:gem/ansi#lib/ansi/table.rb:149
  def apply_format(str, cell, col, row); end

  # pkg:gem/ansi#lib/ansi/table.rb:123
  def cell_template(max); end

  # Number of columns based on the first row of table.
  #
  # @return [Integer] number of columns
  #
  # pkg:gem/ansi#lib/ansi/table.rb:118
  def column_size; end

  # TODO: make more efficient
  #
  # pkg:gem/ansi#lib/ansi/table.rb:133
  def dividing_line; end

  # TODO: look at the lines and figure out how many columns will fit
  #
  # pkg:gem/ansi#lib/ansi/table.rb:91
  def fit_width; end

  # Calculate the maximun column sizes.
  #
  # @return [Array] maximum size for each column
  #
  # pkg:gem/ansi#lib/ansi/table.rb:99
  def max_columns(fit = T.unsafe(nil)); end
end

