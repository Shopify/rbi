  private

  # pkg:gem/ansi#lib/ansi/progressbar.rb:210
  def bar; end

  # pkg:gem/ansi#lib/ansi/progressbar.rb:166
  def bytes; end

  # pkg:gem/ansi#lib/ansi/progressbar.rb:280
  def colorize(part, style); end

  # pkg:gem/ansi#lib/ansi/progressbar.rb:149
  def convert_bytes(bytes); end

  # pkg:gem/ansi#lib/ansi/progressbar.rb:189
  def elapsed; end

  # pkg:gem/ansi#lib/ansi/progressbar.rb:206
  def eol; end

  # ETA stands for Estimated Time of Arrival.
  #
  # pkg:gem/ansi#lib/ansi/progressbar.rb:179
